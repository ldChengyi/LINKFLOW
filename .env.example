# LinkFlow Environment Configuration
# Copy this file to .env and modify as needed

# ============ 部署隔离（多实例时修改）============
# 容器名前缀，同一台机器部署多套时必须不同（如 linkflow-prod / linkflow-dev）
COMPOSE_PROJECT_NAME=linkflow

# ============ Web (Nginx) ============
# 建议使用 8081 避免与宿主机 80 端口冲突
WEB_PORT=8081
API_HOST=app
API_PORT=8080

# ============ Server ============
SERVER_PORT=8080

# ============ PostgreSQL ============
# Root password for postgres user (used by Docker)
POSTGRES_ROOT_PASSWORD=postgres

# Database connection（app 内部通过 Docker 网络连接，数据库不暴露到宿主机）
DB_HOST=postgres
DB_PORT=5432
DB_NAME=linkflow

# Role credentials (must match init-db.sql)
DB_ADMIN_USER=linkflow_admin
DB_ADMIN_PASSWORD=change_me_admin

DB_APP_USER=linkflow_app
DB_APP_PASSWORD=change_me_app

DB_READ_USER=linkflow_read
DB_READ_PASSWORD=change_me_read

# ============ Redis ============
# app 内部通过 Docker 网络连接（Redis 不暴露到宿主机）
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ JWT ============
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# ============ Log ============
LOG_LEVEL=info
LOG_FILENAME=logs/linkflow.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
LOG_COMPRESS=true

# ============ MQTT ============
MQTT_HOST=0.0.0.0
MQTT_PORT=1883
