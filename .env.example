# LinkFlow Environment Configuration
# Copy this file to .env and modify as needed

# ============ 部署隔离（多实例时修改）============
# 容器名前缀，同一台机器部署多套时必须不同（如 linkflow-prod / linkflow-dev）
COMPOSE_PROJECT_NAME=linkflow

# ============ Web (Nginx) ============
WEB_PORT=80
API_HOST=app
API_PORT=8080

# ============ Server ============
SERVER_PORT=8080

# ============ PostgreSQL ============
# Root password for postgres user (used by Docker)
POSTGRES_ROOT_PASSWORD=postgres

# Database connection（app 内部通过 Docker 网络连接，无需改 DB_PORT）
DB_HOST=postgres
DB_PORT=5432

# 宿主机暴露端口（仅外部工具用，与宿主机已有 PG 冲突时修改，如 5433）
DB_EXPOSE_PORT=5432
DB_NAME=linkflow

# Role credentials (must match init-db.sql)
DB_ADMIN_USER=linkflow_admin
DB_ADMIN_PASSWORD=change_me_admin

DB_APP_USER=linkflow_app
DB_APP_PASSWORD=change_me_app

DB_READ_USER=linkflow_read
DB_READ_PASSWORD=change_me_read

# ============ Redis ============
# app 内部通过 Docker 网络连接（REDIS_ADDR 用 service 名，无需改）
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# 宿主机暴露端口（仅外部工具用，与宿主机已有 Redis 冲突时修改，如 6380）
REDIS_EXPOSE_PORT=6379

# ============ JWT ============
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# ============ Log ============
LOG_LEVEL=info
LOG_FILENAME=logs/linkflow.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
LOG_COMPRESS=true

# ============ MQTT ============
MQTT_HOST=0.0.0.0
MQTT_PORT=1883
