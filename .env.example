# LinkFlow Environment Configuration
# Copy this file to .env and modify as needed

# ============ Web (Nginx) ============
WEB_PORT=80
API_HOST=app
API_PORT=8080

# ============ Server ============
SERVER_PORT=8080

# ============ PostgreSQL ============
# Root password for postgres user (used by Docker)
POSTGRES_ROOT_PASSWORD=postgres

# Database connection
DB_HOST=postgres
DB_PORT=5432
DB_NAME=linkflow

# Role credentials (must match init-db.sql)
DB_ADMIN_USER=linkflow_admin
DB_ADMIN_PASSWORD=change_me_admin

DB_APP_USER=linkflow_app
DB_APP_PASSWORD=change_me_app

DB_READ_USER=linkflow_read
DB_READ_PASSWORD=change_me_read

# ============ Redis ============
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# ============ JWT ============
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# ============ Log ============
LOG_LEVEL=info
LOG_FILENAME=logs/linkflow.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
LOG_COMPRESS=true

# ============ MQTT ============
MQTT_HOST=0.0.0.0
MQTT_PORT=1883
